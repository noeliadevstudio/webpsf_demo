<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plantilla - PSF</title>
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <script defer src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script defer src="/js/gestionFormularios.js"></script>
    <script defer src="/js/votar.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">PSF Equipo</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/">Inicio</a>
                <a class="nav-link active" href="/plantilla">Plantilla</a>
                <% if (user) { %>
                    <% if (user.rol === 'admin') { %>
                        <a class="nav-link" href="/admin">Panel Admin</a>
                    <% } %>
                    <span class="nav-link text-light">¡Hola, <%= user.nombre %>!</span>
                    <a class="nav-link" href="/logout">Cerrar sesión</a>
                <% } else { %>
                    <a class="nav-link" href="/login">Iniciar sesión</a>
                    <a class="nav-link" href="/register">Registrarse</a>
                <% } %>
            </div>
        </div>
    </nav>
<main>
    <div class="container mt-5">
        <div class="d-flex align-items-center mb-4">
            <img src="/img/Escudopsf.png" alt="Escudo PSF" class="logo-small">
            <h1 class="mb-0">Plantilla del Equipo</h1>
        </div>
        <div class="row">
            <% jugadores.forEach(jugador => { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <% if (jugador.URL_foto) { %>
                            <img src="<%= jugador.URL_foto %>" class="card-img-top" alt="Foto de <%= jugador.nombre %>" />
                        <% } %>
                        <div class="card-body">
                            <h5 class="card-title"><%= jugador.nombre %> <%= jugador.apellido || '' %></h5>
                            <% if (jugador.mote) { %>
                                <p class="card-text"><strong>Mote:</strong> <%= jugador.mote %></p>
                            <% } %>
                            <% if (jugador.dorsal != null) { %>
                                <p class="card-text"><strong>Dorsal:</strong> <%= jugador.dorsal %></p>
                            <% } %>
                            <p class="card-text">Posición: <%= jugador.posicion || 'No definida' %></p>
                            <% if (jugador.historico) { %>
                                <p class="card-text"><strong>Histórico:</strong> <%= jugador.historico %></p>
                            <% } %>
                            <p class="card-text">Partidos: <%= jugador.partidos || 0 %></p>
                            <p class="card-text">Goles: <%= jugador.goles || 0 %></p>
                            <p class="card-text">Asistencias: <%= jugador.asistencias || 0 %></p>
                            <p class="card-text">Tarjetas Amarillas: <%= jugador.tarjetas_amarillas || 0 %></p>
                            <p class="card-text">Tarjetas Rojas: <%= jugador.tarjetas_rojas || 0 %></p>
                            <button class="btn btn-green" data-bs-toggle="modal" data-bs-target="#modal<%= jugador.id %>">Ver Detalles</button>
                        </div>
                    </div>
                </div>

        
                <div class="modal fade" id="modal<%= jugador.id %>" tabindex="-1" aria-labelledby="modalLabel<%= jugador.id %>" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="modalLabel<%= jugador.id %>"><%= jugador.nombre %> <%= jugador.apellido || '' %></h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <% if (jugador.URL_foto) { %>
                                    <img src="<%= jugador.URL_foto %>" class="img-fluid mb-3" alt="Foto de <%= jugador.nombre %>" />
                                <% } %>
                                <% if (jugador.mote) { %>
                                    <p><strong>Mote:</strong> <%= jugador.mote %></p>
                                <% } %>
                                <% if (jugador.dorsal != null) { %>
                                    <p><strong>Dorsal:</strong> <%= jugador.dorsal %></p>
                                <% } %>
                                <p><strong>Posición:</strong> <%= jugador.posicion || 'No definida' %></p>
                                <% if (jugador.historico) { %>
                                    <p><strong>Histórico:</strong> <%= jugador.historico %></p>
                                <% } %>
                                <p><strong>Partidos:</strong> <%= jugador.partidos || 0 %></p>
                                <p><strong>Goles:</strong> <%= jugador.goles || 0 %></p>
                                <p><strong>Asistencias:</strong> <%= jugador.asistencias || 0 %></p>
                                <p><strong>Tarjetas Amarillas:</strong> <%= jugador.tarjetas_amarillas || 0 %></p>
                                <p><strong>Tarjetas Rojas:</strong> <%= jugador.tarjetas_rojas || 0 %></p>
                                <% if (user) { %>
                                    <button type="button" class="btn btn-pink votar-btn" data-jugador-id="<%= jugador.id %>">
                                        <img src="/img/estrellita.png" alt="Estrella" class="star-icon button-icon">Votar
                                    </button>
                                     <div class="mensaje-voto mt-3"></div>
                                <% } else { %>
                                    <p>Inicia sesión para votar.</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

 </main>

<footer class="footer-psf">
    <div class="container text-center">
        <p class="mb-0">
            © 2026 PSF — Proyecto Intermodular · IES Virgen de la Paloma
        </p>
    </div>
</footer>
</body>
</html>